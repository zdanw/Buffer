{
  "builds": [
    {
      "src": "wsgi.py",
      "use": "@vercel/python",
      "config": {
        "excludeFiles": [
          "models/**",
          "*.md",
          "*.toml",
          "*.example",
          ".git/**",
          "data/**",
          "__pycache__/**",
          "*.pyc"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "wsgi.py"
    }
  ],
  "env": {
    "FLASK_ENV": "production",
    "USE_REMOTE_MODELS": "true"
  }
}