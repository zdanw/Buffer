{
  "builds": [
    {
      "src": "app/static/**/*",
      "use": "@vercel/static"
    },
    {
      "src": "app/templates/index.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/app/templates/index.html"
    }
  ],
  "env": {
    "API_BASE_URL": "@api_base_url"
  }
}