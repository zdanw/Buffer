# === Buffer平台API配置 ===
# 从Buffer开发者控制台获取：https://buffer.com/developers/api
BUFFER_API_TOKEN=your-buffer-api-token

# === Doubao AI API配置（图片生成） ===
# API地址（默认即可）
DOUBAO_API_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
# 从火山引擎控制台获取API密钥
DOUBAO_API_KEY=your-doubao-api-key
DOUBAO_MODEL_ID=Doubao-Seedream-4.5
DOUBAO_ASPECT_RATIO=1:1

# === DeepSeek API配置（文本生成） ===
# API地址（默认即可）
DEEPSEEK_API_URL=https://api.deepseek.com/v1
# 从DeepSeek控制台获取API密钥
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat

# === GitHub 图床配置 ===
# 启用 GitHub 图床（true/false）
GITHUB_IMAGE_BED_ENABLED=false
# GitHub 个人访问令牌（需勾选 repo 权限）
# 获取地址: https://github.com/settings/tokens/new
GITHUB_TOKEN=your-github-token
# GitHub 用户名
GITHUB_USER=your-github-username
# 仓库名称（必须是公开仓库）
GITHUB_REPO=your-repo-name
# 分支名称（默认 main）
GITHUB_BRANCH=main
# 仓库中存储图片的文件夹（默认 images）
GITHUB_IMAGE_FOLDER=images
